# Copy this file to .env and fill in your API keys
# Never commit .env to git

# Groq — free tier, used for answer refinement (03d)
# Get at: https://console.groq.com/
GROQ_API_KEY=

# Cohere — used for Tamil translation (07)
# Get at: https://dashboard.cohere.com/
COHERE_API_KEY=

# OpenRouter — used for structural diversity generation (03g)
# Get at: https://openrouter.ai/
OPENROUTER_API_KEY=

# Adaption — used for dataset adaptation (04)
# Get at: https://www.adaption.ai/
ADAPTION_API_KEY=
